{
  "artificialDelayMilliseconds": 1000,
  "keepExistingTerminalsOpen": false,
  "runOnStartup": true,
  "terminals": [
    {
      "splitTerminals": [
        {
          "name": "yarn install",
          "commands": ["set -a; . ./.env; set +a && yarn install"],
          "shouldRunCommands": false
        }
      ]
    },
    {
      "splitTerminals": [
        {
          "name": "yarn up",
          "commands": [
            "set -a; . ./.env; set +a && yarn up @eduriam/ui-core && yarn up @eduriam/ui-x"
          ],
          "shouldRunCommands": false
        }
      ]
    },
    {
      "splitTerminals": [
        {
          "name": "storybook",
          "commands": ["yarn storybook"],
          "shouldRunCommands": false
        }
      ]
    },
    {
      "splitTerminals": [
        {
          "name": "test:e2e",
          "commands": ["yarn test:e2e -- --tags \"@lesson-learning\""],
          "shouldRunCommands": false
        }
      ]
    },
    {
      "splitTerminals": [
        {
          "name": "lint",
          "commands": ["docker-compose up --build eduriam-frontend-lint"],
          "shouldRunCommands": false
        }
      ]
    },
    {
      "splitTerminals": [
        {
          "name": "build",
          "commands": ["docker-compose up --build eduriam-frontend-build"],
          "shouldRunCommands": false
        }
      ]
    },
    {
      "splitTerminals": [
        {
          "name": "dev",
          "commands": ["yarn dev"],
          "shouldRunCommands": false
        }
      ]
    }
  ]
}
