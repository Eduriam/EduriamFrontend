# GitHub NPM Auth Token
NPM_AUTH_TOKEN=to_be_modified

# API Configuration
NEXT_PUBLIC_API_URL=to_be_modified

# Google Analytics
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=to_be_modified

# Google AdSense
NEXT_PUBLIC_GOOGLE_ADSENSE_ID=to_be_modified

# Mockoon Configuration
# Path to the Mockoon data file (JSON)
# Windows example: C:\path\to\EduriamApiMock\netlify\functions\datafile.json
# Linux/Mac example: /path/to/EduriamApiMock/netlify/functions/datafile.json
MOCKOON_DATA_FILE=to_be_modified

# Mockoon API Port (optional, defaults to 3001)
MOCKOON_PORT=3001
