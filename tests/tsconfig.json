{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "target": "es2018",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "noEmit": false
  },
  "ts-node": {
    "compilerOptions": {
      "module": "commonjs"
    }
  }
}
